# Local shell secrets template
#
# Copy this file to ~/.config/shell/secrets.zsh and fill in real values.
# The real secrets.zsh file is ignored by the dotfiles repo.

# Required when using OpenCode's jCodeMunch GLM summarizer provider.
# Referenced by ~/.config/opencode/opencode.json as {env:ZHIPUAI_API_KEY}.
export ZHIPUAI_API_KEY="replace-with-z-ai-or-zhipu-token"

# OpenCode's built-in Z.AI/Zhipu providers look for ZHIPU_API_KEY.
# Keep this as an alias so the token has one source of truth.
export ZHIPU_API_KEY="$ZHIPUAI_API_KEY"

# Optional. Only export this in every shell if Hugging Face CLI/plugins need it.
# WhisperX conversation transcription normally reads its token from:
# ~/.config/transcribe-watcher/hf_token
# instead of this environment variable.
# export HF_TOKEN="replace-with-hugging-face-token"

# retired with the old Claude Code ccg alias: ANTHROPIC_AUTH_TOKEN was only
# used against Z.ai's Anthropic-compatible endpoint. That alias was removed
# when Claude Code was cleaned up from this machine.
